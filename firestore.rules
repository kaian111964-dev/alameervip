rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to media items, live channels, categories, and announcements
    match /media_items/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /live_channels/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /category_items/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /announcements/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
